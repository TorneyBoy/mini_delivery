# =====================================================
# Mini Delivery 项目 .gitignore 配置文件
# =====================================================

# -----------------------------------------------------
# Java / Maven / Spring Boot
# -----------------------------------------------------

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Java编译文件
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Spring Boot
*.log
*.gz

# -----------------------------------------------------
# 微信小程序
# -----------------------------------------------------

# 小程序IDE配置
miniprogram_npm/
miniprogram/node_modules/

# 小程序编译产物
*.wxapkg

# 项目私有配置（包含appid等敏感信息）
miniprogram/project.private.config.json
miniprogram/.env.js

# -----------------------------------------------------
# IDE 和编辑器
# -----------------------------------------------------

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.settings/
.classpath
.project
.metadata/
bin/
tmp/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Sublime Text
*.sublime-workspace
*.sublime-project

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# -----------------------------------------------------
# 操作系统
# -----------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------
# 敏感配置文件（包含密码、密钥等）
# -----------------------------------------------------

# 应用配置（包含数据库密码、微信密钥等）
server/src/main/resources/application-prod.yml
server/src/main/resources/application-dev.yml
application-local.yml
application-secret.yml

# 微信支付证书
server/src/main/resources/*.pem
server/src/main/resources/*.p12
server/src/main/resources/apiclient_*.pem
server/src/main/resources/apiclient_*.p12

# SSL证书文件（nginx/ssl目录）
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt
nginx/ssl/*.csr
nginx/ssl/fullchain.pem
nginx/ssl/privkey.pem

# 环境变量文件
.env
.env.local
.env.*.local

# -----------------------------------------------------
# 日志文件
# -----------------------------------------------------

logs/
*.log
log/
server/logs/

# -----------------------------------------------------
# 上传文件和数据目录
# -----------------------------------------------------

# 上传的图片和文件（运行时生成）
server/data/upload/*
!server/data/upload/.gitkeep

# 数据库文件（如果有本地数据库）
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------
# Docker
# -----------------------------------------------------

# Docker volumes（本地挂载数据）
mysql-data/
redis-data/

# -----------------------------------------------------
# 临时文件和缓存
# -----------------------------------------------------

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*.cache

# 测试覆盖率报告
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------
# 其他
# -----------------------------------------------------

# 备份文件
*.backup
*.old

# 压缩包
*.7z
*.dmg
*.iso

# 敏感文档（如果需要）
# 开发需求.pdf
