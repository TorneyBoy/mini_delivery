/* pages/driver/picking/picking.wxss */
.picking-container {
    min-height: 100vh;
    background: linear-gradient(180deg, #f0f5ff 0%, #f5f7fa 100%);
}

/* 顶部标题栏 */
.header-section {
    background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
    padding: 30rpx 30rpx 40rpx;
}

.header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
}

.header-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #fff;
}

.progress-badge {
    background: rgba(255, 255, 255, 0.2);
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
}

.progress-text {
    font-size: 26rpx;
    color: #fff;
}

/* 进度条 */
.progress-bar-wrapper {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.progress-bar {
    flex: 1;
    height: 12rpx;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 6rpx;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: #fff;
    border-radius: 6rpx;
    transition: width 0.3s ease;
}

.progress-percent {
    font-size: 26rpx;
    color: #fff;
    min-width: 60rpx;
    text-align: right;
}

/* 拣货清单 */
.picking-list {
    height: calc(100vh - 280rpx);
    padding: 20rpx;
    box-sizing: border-box;
}

.picking-item {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    padding: 24rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
    box-sizing: border-box;
    width: calc(100% - 40rpx);
    max-width: 100%;
    overflow: hidden;
}

.picking-item.completed {
    background: linear-gradient(135deg, #f6ffed 0%, #e6fffb 100%);
    border: 2rpx solid #52c41a;
}

.item-left {
    margin-right: 20rpx;
}

.item-icon {
    width: 80rpx;
    height: 80rpx;
    background: linear-gradient(135deg, #e6f7ff 0%, #f0f5ff 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
}

.picking-item.completed .item-icon {
    background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
    color: #fff;
}

.item-content {
    flex: 1;
}

.item-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12rpx;
}

.item-name {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
}

.item-status {
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
    font-size: 22rpx;
}

.item-status.pending {
    background: #fff7e6;
    color: #fa8c16;
}

.item-status.done {
    background: #f6ffed;
    color: #52c41a;
}

.item-info {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.info-row {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.info-label {
    font-size: 24rpx;
    color: #999;
}

.info-value {
    font-size: 26rpx;
    color: #333;
    font-weight: 500;
}

.info-value.highlight {
    color: #52c41a;
}

.item-action {
    margin-left: 20rpx;
}

.btn-complete {
    padding: 16rpx 24rpx;
    background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
    color: #fff;
    font-size: 24rpx;
    font-weight: 500;
    border-radius: 30rpx;
    border: none;
}

.btn-complete.done {
    background: #f5f5f5;
    color: #999;
}

/* 空状态 */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
}

.empty-icon {
    font-size: 120rpx;
    margin-bottom: 20rpx;
}

.empty-text {
    font-size: 32rpx;
    color: #999;
    margin-bottom: 12rpx;
}

.empty-tip {
    font-size: 26rpx;
    color: #ccc;
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 26rpx;
}

.loading-spinner {
    width: 48rpx;
    height: 48rpx;
    border: 4rpx solid #f0f0f0;
    border-top-color: #1890ff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: 16rpx;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* 全部完成提示 */
.all-done-tip {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60rpx 40rpx;
    background: linear-gradient(135deg, #f6ffed 0%, #e6fffb 100%);
    border-radius: 16rpx;
    margin: 20rpx 0;
}

.done-icon {
    font-size: 80rpx;
    margin-bottom: 16rpx;
}

.done-text {
    font-size: 32rpx;
    font-weight: 600;
    color: #52c41a;
    margin-bottom: 8rpx;
}

.done-tip {
    font-size: 26rpx;
    color: #999;
}

/* 底部占位 */
.bottom-placeholder {
    height: 200rpx;
}

/* 底部操作栏 */
.action-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 100rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20rpx 30rpx;
    background: #fff;
    box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
    z-index: 100;
}

.action-info {
    display: flex;
    align-items: baseline;
    gap: 8rpx;
}

.action-label {
    font-size: 28rpx;
    color: #666;
}

.action-count {
    font-size: 40rpx;
    font-weight: 600;
    color: #fa8c16;
}

.btn-all-complete {
    background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
    color: #fff;
    font-size: 30rpx;
    font-weight: 500;
    padding: 20rpx 40rpx;
    border-radius: 40rpx;
    border: none;
}

/* 头部操作区域 */
.header-actions {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.order-manage-btn {
    display: flex;
    align-items: center;
    gap: 8rpx;
    background: rgba(255, 255, 255, 0.2);
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
}

.manage-icon {
    font-size: 26rpx;
}

.manage-text {
    font-size: 24rpx;
    color: #fff;
}

/* 订单管理弹窗 */
.order-manage-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: none;
    align-items: flex-end;
    justify-content: center;
}

.order-manage-modal.show {
    display: flex;
}

.order-manage-content {
    width: 100%;
    max-height: 70vh;
    background: #fff;
    border-radius: 24rpx 24rpx 0 0;
    overflow: hidden;
    animation: slideUp 0.3s ease;
}

@keyframes slideUp {
    from {
        transform: translateY(100%);
    }
    to {
        transform: translateY(0);
    }
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
}

.close-btn {
    font-size: 48rpx;
    color: #999;
    line-height: 1;
}

.order-manage-list {
    max-height: 60vh;
    padding: 20rpx;
}

.manage-order-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f9f9f9;
    border-radius: 12rpx;
    padding: 24rpx;
    margin-bottom: 16rpx;
}

.manage-order-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8rpx;
    min-width: 0;
}

.manage-shop-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.manage-order-no {
    font-size: 22rpx;
    color: #999;
}

.manage-order-amount {
    font-size: 28rpx;
    font-weight: 600;
    color: #ff4d4f;
}

.manage-order-actions {
    margin-left: 20rpx;
}

.btn-remove {
    padding: 12rpx 24rpx;
    background: #fff;
    border: 1rpx solid #ff4d4f;
    border-radius: 8rpx;
    font-size: 24rpx;
    color: #ff4d4f;
}

.empty-orders {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60rpx 0;
    color: #999;
    font-size: 28rpx;
}

/* 修改订单按钮 */
.modify-btn {
    display: flex;
    align-items: center;
    gap: 8rpx;
    background: rgba(255, 255, 255, 0.2);
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
}

.modify-icon {
    font-size: 26rpx;
}

.modify-text {
    font-size: 24rpx;
    color: #fff;
}

/* 修改订单弹窗 */
.modify-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: none;
    align-items: flex-end;
    justify-content: center;
}

.modify-modal.show {
    display: flex;
}

.modify-content {
    width: 100%;
    max-height: 85vh;
    background: #fff;
    border-radius: 24rpx 24rpx 0 0;
    overflow: hidden;
    animation: slideUp 0.3s ease;
    display: flex;
    flex-direction: column;
}

.modify-section {
    padding: 20rpx 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20rpx;
}

.section-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
}

.select-all-btn {
    padding: 8rpx 20rpx;
    background: #f0f5ff;
    border-radius: 20rpx;
    font-size: 24rpx;
    color: #1890ff;
}

.add-product-btn {
    padding: 8rpx 20rpx;
    background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
    border-radius: 20rpx;
    font-size: 24rpx;
    color: #fff;
}

/* 订单选择列表 */
.order-select-list {
    max-height: 300rpx;
}

.order-select-item {
    display: flex;
    align-items: flex-start;
    padding: 20rpx;
    background: #f9f9f9;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
    border: 2rpx solid transparent;
    transition: all 0.3s ease;
}

.order-select-item.selected {
    background: #e6f7ff;
    border-color: #1890ff;
}

.order-checkbox {
    width: 40rpx;
    height: 40rpx;
    border: 2rpx solid #d9d9d9;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-right: 16rpx;
    font-size: 24rpx;
    color: #fff;
    flex-shrink: 0;
}

.order-select-item.selected .order-checkbox {
    background: #1890ff;
    border-color: #1890ff;
}

.order-info {
    display: flex;
    align-items: center;
    gap: 16rpx;
    margin-bottom: 8rpx;
}

.order-shop-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
}

.order-amount {
    font-size: 26rpx;
    color: #ff4d4f;
    font-weight: 500;
}

.order-items-preview {
    font-size: 22rpx;
    color: #999;
    line-height: 1.5;
}

/* 修改项列表 */
.modify-items-list {
    max-height: 300rpx;
    overflow-y: auto;
}

.modify-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20rpx;
    background: #f9f9f9;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
}

.modify-item-info {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.modify-item-name {
    font-size: 28rpx;
    color: #333;
}

.modify-item-type {
    padding: 4rpx 12rpx;
    border-radius: 12rpx;
    font-size: 20rpx;
}

.modify-item-type.add {
    background: #f6ffed;
    color: #52c41a;
}

.modify-item-type.modify {
    background: #fff7e6;
    color: #fa8c16;
}

.modify-item-actions {
    display: flex;
    align-items: center;
    gap: 16rpx;
}

.quantity-btn {
    width: 48rpx;
    height: 48rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    font-weight: 600;
}

.quantity-btn.minus {
    background: #f5f5f5;
    color: #666;
}

.quantity-btn.plus {
    background: #1890ff;
    color: #fff;
}

.quantity-value {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
    min-width: 60rpx;
    text-align: center;
}

.remove-item-btn {
    width: 40rpx;
    height: 40rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    color: #ff4d4f;
}

.empty-modify {
    padding: 40rpx;
    text-align: center;
    color: #999;
    font-size: 26rpx;
}

/* 修改弹窗底部 */
.modify-footer {
    display: flex;
    gap: 20rpx;
    padding: 20rpx 30rpx;
    padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
    background: #fff;
    border-top: 1rpx solid #f0f0f0;
}

.btn-cancel {
    flex: 1;
    padding: 24rpx;
    background: #f5f5f5;
    color: #666;
    font-size: 30rpx;
    border-radius: 40rpx;
    border: none;
}

.btn-submit {
    flex: 2;
    padding: 24rpx;
    background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
    color: #fff;
    font-size: 30rpx;
    font-weight: 500;
    border-radius: 40rpx;
    border: none;
}

.btn-submit.loading {
    opacity: 0.7;
}

/* 商品选择弹窗 */
.product-select-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1100;
    display: none;
    align-items: flex-end;
    justify-content: center;
}

.product-select-modal.show {
    display: flex;
}

.product-select-content {
    width: 100%;
    max-height: 70vh;
    background: #fff;
    border-radius: 24rpx 24rpx 0 0;
    overflow: hidden;
    animation: slideUp 0.3s ease;
}

.product-list {
    max-height: 60vh;
    padding: 20rpx;
}

.product-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx;
    background: #f9f9f9;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
}

.product-info {
    display: flex;
    flex-direction: column;
    gap: 8rpx;
}

.product-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
}

.product-category {
    font-size: 22rpx;
    color: #999;
}

.product-price {
    font-size: 26rpx;
    color: #ff4d4f;
    font-weight: 500;
}

.empty-products {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60rpx 0;
    color: #999;
    font-size: 28rpx;
}

/* 订单商品详情列表 */
.order-info-wrapper {
    flex: 1;
}

.order-items-detail {
    margin-top: 16rpx;
    padding-top: 16rpx;
    border-top: 1rpx dashed #e8e8e8;
}

.order-item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12rpx 0;
}

.order-item-row .item-name {
    font-size: 24rpx;
    color: #666;
    flex: 1;
}

.item-quantity-control {
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.qty-btn {
    width: 44rpx;
    height: 44rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    font-weight: 600;
}

.qty-btn.minus {
    background: #fff7e6;
    color: #fa8c16;
    border: 1rpx solid #ffd591;
}

.qty-btn.plus {
    background: #e6f7ff;
    color: #1890ff;
    border: 1rpx solid #91d5ff;
}

/* 数量显示区域（包含输入框和单位） */
.qty-display {
    display: flex;
    align-items: center;
    gap: 4rpx;
}

.qty-input {
    width: 80rpx;
    height: 44rpx;
    text-align: center;
    font-size: 26rpx;
    color: #333;
    border: 1rpx solid #d9d9d9;
    border-radius: 8rpx;
    background: #fff;
}

.qty-unit {
    font-size: 22rpx;
    color: #666;
    min-width: 30rpx;
}

/* 修改项目标店铺 */
.modify-item-target {
    font-size: 20rpx;
    color: #1890ff;
    background: #e6f7ff;
    padding: 2rpx 8rpx;
    border-radius: 8rpx;
}

/* 数量输入框 */
.quantity-input {
    width: 80rpx;
    height: 48rpx;
    text-align: center;
    font-size: 28rpx;
    color: #333;
    border: 1rpx solid #d9d9d9;
    border-radius: 8rpx;
    background: #fff;
}

/* 调整订单选择列表高度 */
.order-select-list {
    max-height: 500rpx;
}
