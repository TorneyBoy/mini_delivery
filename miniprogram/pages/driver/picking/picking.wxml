<!-- pages/driver/picking/picking.wxml -->
<view class="picking-container">
    <!-- 顶部标题栏 -->
    <view class="header-section">
        <view class="header-bar">
            <text class="header-title">待拣货清单</text>
            <view class="header-actions">
                <view class="order-manage-btn" bindtap="onToggleOrderManage" wx:if="{{selectedOrders.length > 0}}">
                    <text class="manage-icon">📋</text>
                    <text class="manage-text">订单管理</text>
                </view>
                <view class="progress-badge" wx:if="{{pickingList.items.length > 0}}">
                    <text class="progress-text">{{completedCount}}/{{pickingList.items.length}}</text>
                </view>
            </view>
        </view>
        <!-- 进度条 -->
        <view class="progress-bar-wrapper" wx:if="{{pickingList.items.length > 0}}">
            <view class="progress-bar">
                <view class="progress-fill" style="width: {{progressPercent}}%"></view>
            </view>
            <text class="progress-percent">{{progressPercent}}%</text>
        </view>
    </view>

    <!-- 订单管理弹窗 -->
    <view class="order-manage-modal {{showOrderManage ? 'show' : ''}}" catchtap="onCloseOrderManage">
        <view class="order-manage-content" catchtap="stopPropagation">
            <view class="modal-header">
                <text class="modal-title">已选订单 ({{selectedOrders.length}}单)</text>
                <view class="close-btn" catchtap="onCloseOrderManage">×</view>
            </view>
            <scroll-view class="order-manage-list" scroll-y>
                <view class="manage-order-item" wx:for="{{selectedOrders}}" wx:key="id">
                    <view class="manage-order-info">
                        <text class="manage-shop-name">{{item.shopName || '店铺'}}</text>
                        <text class="manage-order-no">{{item.orderNo}}</text>
                        <text class="manage-order-amount">¥{{item.totalAmount}}</text>
                    </view>
                    <view class="manage-order-actions">
                        <view class="btn-remove" catchtap="onRemoveOrder" data-id="{{item.id}}" data-name="{{item.shopName}}">
                            <text>移除</text>
                        </view>
                    </view>
                </view>
                <view class="empty-orders" wx:if="{{selectedOrders.length === 0}}">
                    <text>暂无已选订单</text>
                </view>
            </scroll-view>
        </view>
    </view>

    <!-- 拣货清单 -->
    <scroll-view class="picking-list" scroll-y enhanced>
        <!-- 商品列表 -->
        <view class="picking-item {{item.status === 1 ? 'completed' : ''}}" 
              wx:for="{{pickingList.items}}" 
              wx:key="id">
            <view class="item-left">
                <view class="item-icon">
                    <text wx:if="{{item.status === 1}}">✓</text>
                    <text wx:else>📦</text>
                </view>
            </view>
            <view class="item-content">
                <view class="item-header">
                    <text class="item-name">{{item.productName}}</text>
                    <view class="item-status {{item.status === 1 ? 'done' : 'pending'}}">
                        <text>{{item.status === 1 ? '已完成' : '待拣货'}}</text>
                    </view>
                </view>
                <view class="item-info">
                    <view class="info-row">
                        <text class="info-label">总数量</text>
                        <text class="info-value">{{item.totalQuantity}} {{item.unit || '斤'}}</text>
                    </view>
                    <view class="info-row" wx:if="{{item.status === 1}}">
                        <text class="info-label">已拣数量</text>
                        <text class="info-value highlight">{{item.pickedQuantity}} {{item.unit || '斤'}}</text>
                    </view>
                </view>
            </view>
            <view class="item-action">
                <button class="btn-complete {{item.status === 1 ? 'done' : ''}}" 
                        catchtap="onCompletePicking" 
                        data-id="{{item.id}}" 
                        data-name="{{item.productName}}"
                        disabled="{{item.status === 1}}">
                    <text wx:if="{{item.status === 1}}">已完成</text>
                    <text wx:else>拣货完成</text>
                </button>
            </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{!pickingList || pickingList.items.length === 0 && !loading}}">
            <text class="empty-icon">📦</text>
            <text class="empty-text">暂无拣货任务</text>
            <text class="empty-tip">请先在"待分配"页面选择订单</text>
        </view>

        <!-- 加载状态 -->
        <view class="loading-state" wx:if="{{loading}}">
            <view class="loading-spinner"></view>
            <text>加载中...</text>
        </view>

        <!-- 全部完成提示 -->
        <view class="all-done-tip" wx:if="{{pickingList && pickingList.allCompleted}}">
            <text class="done-icon">🎉</text>
            <text class="done-text">拣货已全部完成！</text>
            <text class="done-tip">即将自动跳转到送货页面</text>
        </view>

        <!-- 底部占位 -->
        <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部操作栏 -->
    <view class="action-bar" wx:if="{{pickingList && pickingList.items.length > 0 && !pickingList.allCompleted}}">
        <view class="action-info">
            <text class="action-label">剩余</text>
            <text class="action-count">{{pendingCount}}</text>
            <text class="action-label">项待拣货</text>
        </view>
        <button class="btn-all-complete" bindtap="onCompleteAll">
            <text>一键完成全部</text>
        </button>
    </view>

    <!-- 底部导航栏 -->
    <driver-tab-bar current="{{1}}" pickingCount="{{pendingCount}}" />
</view>
