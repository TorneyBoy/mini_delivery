<!-- pages/driver/profile/profile.wxml -->
<view class="profile-container">
    <!-- 顶部用户信息 -->
    <view class="header-section">
        <view class="user-info">
            <view class="avatar">
                <text class="avatar-icon">👤</text>
            </view>
            <view class="user-detail">
                <text class="user-name">{{driverInfo.name || '司机'}}</text>
                <text class="user-phone">{{driverInfo.phone || ''}}</text>
            </view>
        </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-section">
        <view class="section-title">送货统计</view>
        <view class="stats-grid">
            <view class="stat-item">
                <text class="stat-value">{{statistics.todayOrders || 0}}</text>
                <text class="stat-label">今日订单</text>
            </view>
            <view class="stat-item">
                <text class="stat-value">{{statistics.todayShops || 0}}</text>
                <text class="stat-label">今日店铺</text>
            </view>
            <view class="stat-item">
                <text class="stat-value">{{statistics.totalOrders || 0}}</text>
                <text class="stat-label">累计订单</text>
            </view>
            <view class="stat-item">
                <text class="stat-value">{{statistics.totalAmount || '0.00'}}</text>
                <text class="stat-label">累计金额</text>
            </view>
        </view>
    </view>

    <!-- 历史送货记录 -->
    <view class="history-section">
        <view class="section-title">历史送货记录</view>
        <scroll-view class="history-list" scroll-y enhanced>
            <view class="history-item" wx:for="{{historyList}}" wx:key="id">
                <view class="history-left">
                    <text class="history-date">{{item.date}}</text>
                    <text class="history-shops">{{item.shopCount}} 家店铺</text>
                </view>
                <view class="history-right">
                    <text class="history-orders">{{item.orderCount}} 单</text>
                    <text class="history-amount">¥{{item.totalAmount}}</text>
                </view>
            </view>
            
            <!-- 空状态 -->
            <view class="empty-state" wx:if="{{historyList.length === 0 && !loading}}">
                <text class="empty-icon">📋</text>
                <text class="empty-text">暂无历史记录</text>
            </view>

            <!-- 加载状态 -->
            <view class="loading-state" wx:if="{{loading}}">
                <view class="loading-spinner"></view>
                <text>加载中...</text>
            </view>

            <!-- 底部占位 -->
            <view class="bottom-placeholder"></view>
        </scroll-view>
    </view>

    <!-- 底部操作 -->
    <view class="action-section">
        <button class="btn-logout" bindtap="onLogout">
            <text class="logout-icon">🚪</text>
            <text>退出登录</text>
        </button>
    </view>

    <!-- 底部导航栏 -->
    <driver-tab-bar current="{{3}}" />
</view>
