<!-- pages/driver/upload-product/upload-product.wxml -->
<view class="container">
    <!-- 搜索栏 -->
    <view class="search-bar">
        <view class="search-input-wrapper">
            <text class="search-icon">🔍</text>
            <input 
                class="search-input" 
                placeholder="搜索商品名称" 
                value="{{searchKeyword}}"
                bindinput="onSearchInput"
            />
            <text class="clear-btn" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</text>
        </view>
    </view>

    <!-- 商品列表 -->
    <view class="product-list">
        <view class="list-header">
            <text class="header-text">商品库 ({{filteredProducts.length}}件)</text>
        </view>

        <!-- 加载状态 -->
        <view class="loading-state" wx:if="{{loading}}">
            <view class="loading-spinner"></view>
            <text>加载中...</text>
        </view>

        <!-- 商品列表 -->
        <view class="product-item" wx:for="{{filteredProducts}}" wx:key="id">
            <view class="product-info">
                <view class="product-image" wx:if="{{item.imageUrl}}" bindtap="previewProductImage" data-url="{{item.imageUrl}}">
                    <image src="{{item.imageUrl}}" mode="aspectFill" />
                </view>
                <view class="product-image placeholder" wx:else>
                    <text class="placeholder-icon">📦</text>
                </view>
                <view class="product-detail">
                    <text class="product-name">{{item.name}}</text>
                    <text class="product-category">{{item.category || '未分类'}}</text>
                    <view class="product-price">
                        <text class="price-label">老客:</text>
                        <text class="price-value">¥{{item.oldPrice}}</text>
                        <text class="price-label" style="margin-left: 16rpx;">新客:</text>
                        <text class="price-value">¥{{item.newPrice}}</text>
                    </view>
                </view>
            </view>
            <view class="product-action">
                <button class="add-image-btn" bindtap="onAddImage" data-id="{{item.id}}">
                    <text class="btn-icon">📷</text>
                    <text class="btn-text">添加图片</text>
                </button>
            </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{!loading && filteredProducts.length === 0}}">
            <text class="empty-icon">📦</text>
            <text class="empty-text" wx:if="{{searchKeyword}}">未找到匹配的商品</text>
            <text class="empty-text" wx:else>暂无商品</text>
        </view>
    </view>

    <!-- 图片上传弹窗 -->
    <view class="modal-mask" wx:if="{{showImageModal}}" bindtap="closeModal">
        <view class="modal-content" catchtap="stopPropagation">
            <view class="modal-header">
                <text class="modal-title">添加商品图片</text>
                <text class="modal-close" bindtap="closeModal">×</text>
            </view>
            
            <view class="modal-body">
                <!-- 商品信息 -->
                <view class="selected-product" wx:if="{{currentProduct}}">
                    <text class="selected-label">商品名称:</text>
                    <text class="selected-name">{{currentProduct.name}}</text>
                </view>

                <!-- 图片上传区域 -->
                <view class="image-upload-section">
                    <view class="image-box" wx:if="{{currentImageUrl}}">
                        <image src="{{currentImageUrl}}" mode="aspectFill" bindtap="previewCurrentImage" />
                        <view class="delete-btn" bindtap="deleteCurrentImage">×</view>
                    </view>
                    <view class="upload-btn" wx:else bindtap="chooseImage">
                        <text class="plus">+</text>
                        <text class="text">拍照或从相册选择</text>
                    </view>
                </view>
            </view>

            <view class="modal-footer">
                <button class="cancel-btn" bindtap="closeModal">取消</button>
                <button class="submit-btn" bindtap="submitRequest" loading="{{submitting}}" disabled="{{submitting || !currentImageUrl}}">
                    提交审核
                </button>
            </view>
        </view>
    </view>
</view>
