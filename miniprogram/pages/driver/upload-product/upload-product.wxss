/* pages/driver/upload-product/upload-product.wxss */
.container {
    padding: 20rpx;
    padding-bottom: 40rpx;
    min-height: 100vh;
    background: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
    background: #fff;
    padding: 20rpx;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
}

.search-input-wrapper {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 40rpx;
    padding: 16rpx 24rpx;
}

.search-icon {
    font-size: 32rpx;
    margin-right: 16rpx;
}

.search-input {
    flex: 1;
    font-size: 28rpx;
    color: #333;
}

.clear-btn {
    font-size: 36rpx;
    color: #999;
    padding: 0 10rpx;
}

/* 商品列表 */
.product-list {
    background: #fff;
    border-radius: 16rpx;
    overflow: hidden;
}

.list-header {
    padding: 24rpx;
    border-bottom: 1rpx solid #eee;
}

.header-text {
    font-size: 28rpx;
    color: #666;
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80rpx 0;
    color: #999;
    font-size: 28rpx;
}

.loading-spinner {
    width: 60rpx;
    height: 60rpx;
    border: 4rpx solid #e0e0e0;
    border-top-color: #1890ff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin-bottom: 20rpx;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* 商品项 */
.product-item {
    display: flex;
    flex-direction: column;
    padding: 24rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.product-item:last-child {
    border-bottom: none;
}

.product-info {
    display: flex;
    align-items: center;
    margin-bottom: 16rpx;
}

.product-image {
    width: 120rpx;
    height: 120rpx;
    border-radius: 12rpx;
    overflow: hidden;
    margin-right: 20rpx;
    flex-shrink: 0;
}

.product-image image {
    width: 100%;
    height: 100%;
}

.product-image.placeholder {
    background: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
}

.placeholder-icon {
    font-size: 48rpx;
}

.product-detail {
    flex: 1;
    min-width: 0;
}

.product-name {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
    display: block;
    margin-bottom: 8rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.product-category {
    font-size: 24rpx;
    color: #999;
    display: block;
    margin-bottom: 8rpx;
}

.product-price {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
}

.price-label {
    font-size: 24rpx;
    color: #999;
}

.price-value {
    font-size: 26rpx;
    color: #ff4d4f;
    font-weight: 500;
    margin-left: 4rpx;
}

/* 添加图片按钮 */
.product-action {
    display: flex;
    justify-content: flex-end;
}

.add-image-btn {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
    font-size: 26rpx;
    padding: 12rpx 24rpx;
    border-radius: 30rpx;
    border: none;
    line-height: 1.4;
}

.add-image-btn::after {
    border: none;
}

.btn-icon {
    margin-right: 8rpx;
    font-size: 28rpx;
}

.btn-text {
    font-size: 26rpx;
}

/* 空状态 */
.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
}

.empty-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
}

.empty-text {
    font-size: 28rpx;
    color: #999;
}

/* 弹窗遮罩 */
.modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    width: 90%;
    max-width: 640rpx;
    background: #fff;
    border-radius: 20rpx;
    overflow: hidden;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
}

.modal-close {
    font-size: 48rpx;
    color: #999;
    line-height: 1;
}

.modal-body {
    padding: 30rpx;
}

.selected-product {
    display: flex;
    align-items: center;
    margin-bottom: 30rpx;
    padding: 20rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
}

.selected-label {
    font-size: 28rpx;
    color: #666;
}

.selected-name {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
    margin-left: 8rpx;
}

/* 图片上传区域 */
.image-upload-section {
    display: flex;
    justify-content: center;
}

.image-upload-section .image-box {
    position: relative;
    width: 300rpx;
    height: 300rpx;
}

.image-upload-section .image-box image {
    width: 100%;
    height: 100%;
    border-radius: 12rpx;
}

.image-upload-section .delete-btn {
    position: absolute;
    top: -16rpx;
    right: -16rpx;
    width: 48rpx;
    height: 48rpx;
    background: #ff4d4f;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 32rpx;
    line-height: 1;
}

.image-upload-section .upload-btn {
    width: 300rpx;
    height: 300rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border: 2rpx dashed #ddd;
}

.image-upload-section .upload-btn .plus {
    font-size: 60rpx;
    color: #999;
    line-height: 1;
}

.image-upload-section .upload-btn .text {
    font-size: 26rpx;
    color: #999;
    margin-top: 16rpx;
}

/* 弹窗底部 */
.modal-footer {
    display: flex;
    padding: 20rpx 30rpx 30rpx;
    gap: 20rpx;
}

.cancel-btn {
    flex: 1;
    height: 88rpx;
    line-height: 88rpx;
    background: #f5f5f5;
    color: #666;
    font-size: 30rpx;
    border-radius: 44rpx;
    border: none;
}

.cancel-btn::after {
    border: none;
}

.submit-btn {
    flex: 1;
    height: 88rpx;
    line-height: 88rpx;
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
    font-size: 30rpx;
    border-radius: 44rpx;
    border: none;
}

.submit-btn::after {
    border: none;
}

.submit-btn[disabled] {
    background: #ccc;
    color: #fff;
}
