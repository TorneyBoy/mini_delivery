<!-- pages/driver/product-requests/product-requests.wxml -->
<view class="container">
    <!-- 顶部操作栏 -->
    <view class="header">
        <button class="add-btn" bindtap="goUpload">
            <text class="icon">+</text>
            <text>上传商品图片</text>
        </button>
    </view>

    <!-- 请求列表 -->
    <view class="list-section">
        <view class="list-item" wx:for="{{list}}" wx:key="id">
            <view class="item-header">
                <text class="product-name">{{item.productName}}</text>
                <text class="status status-{{item.status === 0 ? 'pending' : (item.status === 1 ? 'approved' : 'rejected')}}">
                    {{item.statusText}}
                </text>
            </view>
            
            <view class="item-content">
                <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" bindtap="previewImage" data-url="{{item.imageUrl}}" />
                <view class="product-info">
                    <text class="info-row" wx:if="{{item.category}}">类别：{{item.category}}</text>
                    <text class="info-row" wx:if="{{item.description}}">描述：{{item.description}}</text>
                    <text class="info-row">提交时间：{{item.createdAt}}</text>
                </view>
            </view>

            <view class="item-footer" wx:if="{{item.status === 2 && item.rejectReason}}">
                <text class="reject-reason">拒绝原因：{{item.rejectReason}}</text>
            </view>
        </view>

        <!-- 空状态 -->
        <view class="empty-state" wx:if="{{list.length === 0 && !loading}}">
            <text class="empty-icon">📋</text>
            <text class="empty-text">暂无提交记录</text>
            <text class="empty-tip">点击上方按钮上传商品图片</text>
        </view>

        <!-- 加载状态 -->
        <view class="loading-state" wx:if="{{loading}}">
            <view class="loading-spinner"></view>
            <text>加载中...</text>
        </view>
    </view>
</view>
