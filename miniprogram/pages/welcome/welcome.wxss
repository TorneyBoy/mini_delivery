/* pages/welcome/welcome.wxss */
.welcome-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 16rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 平台介绍 */
.intro-section {
  margin: 30rpx 0;
}

.intro-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.intro-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
}

.intro-content {
  flex: 1;
}

.intro-title {
  display: block;
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.intro-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.supplier-section {
  flex: 1;
  margin-top: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.supplier-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.supplier-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.supplier-item:last-child {
  border-bottom: none;
}

.supplier-item:active {
  background: #f5f5f5;
}

.supplier-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
}

.supplier-name {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.supplier-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.loading-section {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}

.empty-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #fff;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
}

.footer {
  margin-top: 40rpx;
  padding: 40rpx 0;
}

.footer-tips {
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #667eea;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-login:active {
  background: #f5f5f5;
}

.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  padding: 0 20rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
}

.btn-register {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

.btn-register:active {
  background: rgba(255, 255, 255, 0.1);
}
