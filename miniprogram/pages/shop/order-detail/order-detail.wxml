<!-- pages/shop/order-detail/order-detail.wxml -->
<view class="order-detail-container">
    <view wx:if="{{loading}}" class="loading-container">
        <text>加载中...</text>
    </view>

    <block wx:if="{{order}}">
        <!-- 订单状态 -->
        <view class="status-section">
            <view class="status-icon">{{order.status === 4 ? '✓' : '⏳'}}</view>
            <text class="status-text">{{statusMap[order.status].text}}</text>
            <text class="status-desc" wx:if="{{order.status === 3}}">司机正在配送中，请保持电话畅通</text>
            <text class="status-desc" wx:if="{{order.status === 4}}">订单已完成</text>
        </view>

        <!-- 配送信息 -->
        <view class="section">
            <view class="section-title">配送信息</view>
            <view class="info-row">
                <text class="info-label">收货日期</text>
                <text class="info-value">{{order.deliveryDate}}</text>
            </view>
            <view class="info-row" wx:if="{{order.driverName}}">
                <text class="info-label">配送司机</text>
                <text class="info-value">{{order.driverName}}</text>
            </view>
            <view class="info-row" wx:if="{{order.receivedAt}}">
                <text class="info-label">收货时间</text>
                <text class="info-value">{{order.receivedAt}}</text>
            </view>
        </view>

        <!-- 送达照片 -->
        <view class="section" wx:if="{{order.deliveryPhoto}}">
            <view class="section-title">送达照片</view>
            <view class="delivery-photo-section">
                <image class="delivery-photo" src="{{order.deliveryPhoto}}" mode="aspectFit" bindtap="onPreviewPhoto" />
                <text class="photo-tip">点击图片可放大查看</text>
            </view>
        </view>

        <!-- 商品列表 -->
        <view class="section">
            <view class="section-title">商品清单</view>
            <view class="product-list">
                <view class="product-item" wx:for="{{order.items}}" wx:key="id">
                    <view class="product-info">
                        <text class="product-name">{{item.productName}}</text>
                        <view class="product-price-row">
                            <text class="product-price">¥{{item.unitPrice}}</text>
                            <text class="product-quantity">x{{item.quantity}}</text>
                        </view>
                    </view>
                    <text class="product-subtotal">¥{{item.subtotal}}</text>
                </view>
            </view>
        </view>

        <!-- 订单信息 -->
        <view class="section">
            <view class="section-title">订单信息</view>
            <view class="info-row" bindtap="onCopyOrderNo">
                <text class="info-label">订单编号</text>
                <view class="info-value-wrapper">
                    <text class="info-value">{{order.orderNo}}</text>
                    <text class="copy-btn">复制</text>
                </view>
            </view>
            <view class="info-row">
                <text class="info-label">下单时间</text>
                <text class="info-value">{{order.createdAt}}</text>
            </view>
        </view>

        <!-- 金额汇总 -->
        <view class="amount-section">
            <view class="amount-row">
                <text class="amount-label">商品总额</text>
                <text class="amount-value">¥{{order.totalAmount}}</text>
            </view>
            <view class="amount-row total">
                <text class="amount-label">合计</text>
                <text class="amount-value">¥{{order.totalAmount}}</text>
            </view>
        </view>

        <!-- 修改提示 -->
        <view class="modify-tip" wx:if="{{canModify}}">
            <text class="tip-text">⏰ {{modifyDeadline}}</text>
            <button class="btn-modify" bindtap="goToEdit">修改订单</button>
        </view>

        <!-- 底部操作 -->
        <view class="bottom-bar" wx:if="{{order.status === 3}}">
            <button class="btn-receive" bindtap="onConfirmReceive">确认收货</button>
        </view>
    </block>
</view>
