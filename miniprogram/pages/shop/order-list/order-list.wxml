<!-- pages/shop/order-list/order-list.wxml -->
<view class="order-list-container">
    <!-- Tab导航 -->
    <view class="tab-nav">
        <view 
            class="tab-item {{currentTab === item.key ? 'active' : ''}}" 
            wx:for="{{tabs}}" 
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onTabChange">
            <text class="tab-text">{{item.name}}</text>
            <view class="tab-line" wx:if="{{currentTab === item.key}}"></view>
        </view>
    </view>

    <!-- 订单列表 -->
    <scroll-view class="order-scroll" scroll-y enhanced bindscrolltolower="onReachBottom">
        <view class="order-list">
            <view class="order-card" wx:for="{{orders}}" wx:key="id">
                <view class="order-header">
                    <text class="order-no">订单号: {{item.orderNo}}</text>
                    <text class="order-status {{statusMap[item.status].class}}">{{statusMap[item.status].text}}</text>
                </view>
                
                <view class="order-products">
                    <view class="product-row" wx:for="{{item.items}}" wx:for-item="product" wx:key="productId">
                        <text class="product-name">{{product.productName}}</text>
                        <text class="product-quantity">x{{product.quantity}}</text>
                        <text class="product-price">¥{{product.subtotal}}</text>
                    </view>
                </view>
                
                <view class="order-footer">
                    <view class="order-info">
                        <text class="delivery-date">📅 {{item.deliveryDate}}</text>
                        <text class="order-amount">合计: <text class="amount">¥{{item.totalAmount}}</text></text>
                    </view>
                    <view class="order-actions">
                        <button
                            class="btn-receive"
                            wx:if="{{item.status === 3}}"
                            data-id="{{item.id}}"
                            catchtap="onConfirmReceive">确认收货</button>
                        <button
                            class="btn-edit"
                            wx:if="{{item.status < 4 && (item.deliveryDate > today || (item.deliveryDate === today && hour < 2))}}"
                            data-id="{{item.id}}"
                            catchtap="goToEdit">修改</button>
                        <button class="btn-detail" data-id="{{item.id}}" catchtap="goToDetail">详情</button>
                    </view>
                </view>
            </view>
        </view>

        <view class="empty" wx:if="{{orders.length === 0 && !loading}}">
            <text class="empty-icon">📋</text>
            <text class="empty-text">暂无订单</text>
        </view>

        <view class="loading" wx:if="{{loading}}">
            <text>加载中...</text>
        </view>

        <view class="no-more" wx:if="{{!hasMore && orders.length > 0 && !loading}}">
            <text>— 没有更多了 —</text>
        </view>

        <!-- 底部占位 -->
        <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部导航栏 -->
    <tab-bar current="{{1}}" />
</view>
