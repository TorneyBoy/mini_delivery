<!-- pages/shop/cart/cart.wxml -->
<view class="cart-container">
    <!-- 购物车列表 -->
    <view class="cart-list" wx:if="{{cartItems.length > 0}}">
        <view class="cart-header">
            <text class="header-title">购物车 ({{totalCount}}件)</text>
            <text class="header-clear" bindtap="onClearCart">清空</text>
        </view>

        <view class="cart-item" wx:for="{{cartItems}}" wx:key="productId">
            <image class="item-image"
                   src="{{item.imageUrl || '/assets/images/default-product.svg'}}"
                   mode="aspectFill"></image>
            <view class="item-info">
                <text class="item-name">{{item.productName}}</text>
                <view class="item-price-row">
                    <text class="item-price">¥{{item.unitPrice}}</text>
                    <text class="item-unit">/{{item.unit}}</text>
                </view>
            </view>
            <view class="item-action">
                <view class="quantity-control">
                    <view class="btn-minus" bindtap="onMinus" data-index="{{index}}">-</view>
                    <input class="quantity-input" type="digit" value="{{item.quantity}}" 
                           bindblur="onInputQuantity" data-index="{{index}}" />
                    <view class="btn-plus" bindtap="onPlus" data-index="{{index}}">+</view>
                </view>
                <view class="item-subtotal">
                    <text class="subtotal-label">小计:</text>
                    <text class="subtotal-value">¥{{item.quantity * item.unitPrice}}</text>
                </view>
                <view class="btn-remove" bindtap="onRemove" data-index="{{index}}">删除</view>
            </view>
        </view>
    </view>

    <!-- 空购物车 -->
    <view class="empty-cart" wx:else>
        <text class="empty-icon">🛒</text>
        <text class="empty-text">购物车空空如也</text>
        <button class="btn-shopping" bindtap="goShopping">去购物</button>
    </view>

    <!-- 底部结算栏 -->
    <view class="bottom-bar" wx:if="{{cartItems.length > 0}}">
        <view class="amount-info">
            <text class="amount-label">合计:</text>
            <text class="amount-value">¥{{totalAmount}}</text>
        </view>
        <button class="btn-checkout" bindtap="goToPreview">去结算({{totalCount}})</button>
    </view>
</view>
