/* pages/shop/index/index.wxss */
.shop-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    display: flex;
    flex-direction: column;
}

/* 顶部区域 */
.header-section {
    background: linear-gradient(135deg, #07c160, #06ad56);
    padding-bottom: 16rpx;
}

.header-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16rpx 24rpx;
    padding-top: calc(16rpx + env(safe-area-inset-top));
}

.shop-info {
    display: flex;
    flex-direction: column;
}

.shop-name {
    color: #fff;
    font-size: 32rpx;
    font-weight: bold;
}

/* 分类导航 */
.category-nav {
    background-color: #fff;
    white-space: nowrap;
    padding: 12rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
}

.category-item {
    display: inline-block;
    padding: 8rpx 24rpx;
    margin: 0 8rpx;
    border-radius: 20rpx;
    transition: all 0.3s ease;
}

.category-item:first-child {
    margin-left: 16rpx;
}

.category-text {
    font-size: 24rpx;
    color: #666;
}

.category-item.active {
    background: linear-gradient(135deg, #07c160, #06ad56);
}

.category-item.active .category-text {
    color: #fff;
    font-weight: 500;
}

/* 商品列表 */
.product-list {
    flex: 1;
    height: 0;
}

.product-grid {
    display: flex;
    flex-wrap: wrap;
    padding: 8rpx;
}

.product-card {
    width: calc(50% - 8rpx);
    margin: 4rpx;
    background-color: #fff;
    border-radius: 8rpx;
    overflow: hidden;
    box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

.product-image {
    width: 100%;
    height: 180rpx;
    background-color: #f8f8f8;
}

.product-info {
    padding: 8rpx 10rpx;
}

.product-name {
    font-size: 24rpx;
    color: #333;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 60rpx;
}

.product-meta {
    display: flex;
    align-items: baseline;
    margin-top: 6rpx;
}

.product-price {
    font-size: 28rpx;
    color: #e64340;
    font-weight: bold;
}

.product-unit {
    font-size: 18rpx;
    color: #999;
    margin-left: 2rpx;
}

.product-action {
    padding: 6rpx 10rpx;
    padding-top: 0;
    display: flex;
    justify-content: flex-end;
}

/* 数量控制 */
.quantity-control {
    display: flex;
    align-items: center;
    background-color: #f5f5f5;
    border-radius: 20rpx;
    overflow: hidden;
}

.btn-minus, .btn-plus {
    width: 36rpx;
    height: 36rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    color: #07c160;
    font-weight: bold;
}

.quantity-text {
    min-width: 40rpx;
    text-align: center;
    font-size: 22rpx;
    color: #333;
    font-weight: 500;
}

.btn-add {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    background: linear-gradient(135deg, #07c160, #06ad56);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2rpx 6rpx rgba(7, 193, 96, 0.3);
}

.add-icon {
    font-size: 28rpx;
    color: #fff;
    font-weight: bold;
}

/* 空状态 */
.empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 0;
}

.empty-icon {
    font-size: 64rpx;
    margin-bottom: 12rpx;
}

.empty-text {
    font-size: 26rpx;
    color: #999;
}

/* 加载状态 */
.loading {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24rpx;
    color: #999;
    font-size: 22rpx;
    gap: 10rpx;
}

.loading-spinner {
    width: 28rpx;
    height: 28rpx;
    border: 2rpx solid #e5e5e5;
    border-top-color: #07c160;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.no-more {
    text-align: center;
    padding: 24rpx;
    color: #ccc;
    font-size: 22rpx;
}

/* 底部占位 */
.bottom-placeholder {
    height: 160rpx;
}

/* 底部购物车栏 */
.cart-bar {
    position: fixed;
    left: 16rpx;
    right: 16rpx;
    bottom: calc(110rpx + env(safe-area-inset-bottom));
    height: 80rpx;
    background-color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16rpx;
    border-radius: 40rpx;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
    z-index: 100;
}

.cart-info {
    display: flex;
    align-items: center;
}

.cart-icon-wrapper {
    margin-right: 12rpx;
}

.cart-icon {
    font-size: 36rpx;
}

.cart-amount-info {
    display: flex;
    align-items: baseline;
}

.cart-label {
    font-size: 22rpx;
    color: #666;
    margin-right: 6rpx;
}

.cart-amount {
    font-size: 32rpx;
    color: #e64340;
    font-weight: bold;
}

.btn-preview {
    width: 140rpx;
    height: 56rpx;
    line-height: 56rpx;
    background: linear-gradient(135deg, #07c160, #06ad56);
    color: #fff;
    font-size: 24rpx;
    font-weight: 500;
    border-radius: 28rpx;
    padding: 0;
}
