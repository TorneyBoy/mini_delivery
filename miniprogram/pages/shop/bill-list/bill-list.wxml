<!-- pages/shop/bill-list/bill-list.wxml -->
<view class="bill-list-container">
    <!-- 账单列表 -->
    <scroll-view class="bill-scroll" scroll-y enhanced bindscrolltolower="onReachBottom">
        <view class="bill-list">
            <view class="bill-card" wx:for="{{bills}}" wx:key="id">
                <view class="bill-header">
                    <view class="bill-info-left">
                        <text class="bill-date">📅 {{item.billDate}}</text>
                        <text class="bill-no">{{item.billNo}}</text>
                    </view>
                    <text class="bill-status {{statusMap[item.status].class}}">{{statusMap[item.status].text}}</text>
                </view>
                
                <view class="bill-content">
                    <view class="bill-amount-row">
                        <text class="amount-label">账单金额</text>
                        <text class="amount-value">¥{{item.totalAmount}}</text>
                    </view>
                </view>
                
                <view class="bill-footer">
                    <text class="bill-time">创建于 {{item.createdAt}}</text>
                    <view class="bill-actions">
                        <button 
                            class="btn-pay" 
                            wx:if="{{item.status === 0}}"
                            data-id="{{item.id}}" 
                            catchtap="onPay">立即支付</button>
                        <button class="btn-detail" data-id="{{item.id}}" catchtap="goToDetail">详情</button>
                    </view>
                </view>
            </view>
        </view>

        <view class="empty" wx:if="{{bills.length === 0 && !loading}}">
            <text class="empty-icon">💰</text>
            <text class="empty-text">暂无账单</text>
        </view>

        <view class="loading" wx:if="{{loading}}">
            <text>加载中...</text>
        </view>

        <view class="no-more" wx:if="{{!hasMore && bills.length > 0 && !loading}}">
            <text>— 没有更多了 —</text>
        </view>

        <!-- 底部占位 -->
        <view class="bottom-placeholder"></view>
    </scroll-view>

    <!-- 底部导航栏 -->
    <tab-bar current="{{2}}" />
</view>
