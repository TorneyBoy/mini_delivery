/* pages/shop/bill-list/bill-list.wxss */
.bill-list-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    display: flex;
    flex-direction: column;
}

/* 账单列表 */
.bill-scroll {
    flex: 1;
    height: 0;
}

.bill-list {
    padding: 20rpx;
}

.bill-card {
    background-color: #fff;
    border-radius: 16rpx;
    margin-bottom: 20rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bill-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24rpx;
    border-bottom: 1rpx solid #f5f5f5;
}

.bill-info-left {
    display: flex;
    flex-direction: column;
}

.bill-date {
    font-size: 30rpx;
    color: #333;
    font-weight: 500;
    margin-bottom: 8rpx;
}

.bill-no {
    font-size: 24rpx;
    color: #999;
}

.bill-status {
    font-size: 26rpx;
    font-weight: 500;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
}

.status-pending {
    background-color: #fff3e0;
    color: #ff9800;
}

.status-paid {
    background-color: #e8f5e9;
    color: #4caf50;
}

/* 账单内容 */
.bill-content {
    padding: 24rpx;
}

.bill-amount-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.amount-label {
    font-size: 28rpx;
    color: #666;
}

.amount-value {
    font-size: 40rpx;
    color: #e64340;
    font-weight: bold;
}

/* 账单底部 */
.bill-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx 24rpx;
    background-color: #fafafa;
}

.bill-time {
    font-size: 24rpx;
    color: #999;
}

.bill-actions {
    display: flex;
    gap: 16rpx;
}

.btn-pay, .btn-detail {
    padding: 0 28rpx;
    height: 64rpx;
    line-height: 64rpx;
    font-size: 26rpx;
    border-radius: 32rpx;
    margin: 0;
}

.btn-pay {
    background: linear-gradient(135deg, #e64340, #d63031);
    color: #fff;
}

.btn-detail {
    background-color: #f5f5f5;
    color: #666;
}

/* 空状态 */
.empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 120rpx 0;
}

.empty-icon {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

.empty-text {
    font-size: 28rpx;
    color: #999;
}

/* 加载状态 */
.loading {
    text-align: center;
    padding: 30rpx;
    color: #999;
    font-size: 26rpx;
}

.no-more {
    text-align: center;
    padding: 30rpx;
    color: #ccc;
    font-size: 24rpx;
}

/* 底部占位 */
.bottom-placeholder {
    height: 140rpx;
}
