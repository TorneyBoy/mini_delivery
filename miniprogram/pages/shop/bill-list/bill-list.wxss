/* pages/shop/bill-list/bill-list.wxss */
.bill-list-container {
    min-height: 100vh;
    background-color: #f5f5f5;
    display: flex;
    flex-direction: column;
}

/* 账单列表 */
.bill-scroll {
    flex: 1;
    height: 0;
}

.bill-list {
    padding: 20rpx;
}

/* 日期分组标题 */
.date-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 16rpx 16rpx;
    background-color: transparent;
}

.date-info {
    display: flex;
    flex-direction: column;
}

.date-text {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
}

.date-stats {
    font-size: 24rpx;
    color: #999;
    margin-top: 4rpx;
}

.date-summary {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
}

.summary-amount {
    font-size: 32rpx;
    font-weight: bold;
    color: #e64340;
}

.summary-status {
    font-size: 22rpx;
    color: #ff9800;
    margin-top: 4rpx;
}

/* 账单卡片 */
.bill-card {
    background-color: #fff;
    border-radius: 16rpx;
    margin-bottom: 16rpx;
    overflow: hidden;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bill-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20rpx 24rpx;
    border-bottom: 1rpx solid #f5f5f5;
}

.bill-info-left {
    display: flex;
    flex-direction: column;
}

.bill-no {
    font-size: 26rpx;
    color: #666;
}

.bill-status {
    font-size: 24rpx;
    font-weight: 500;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
}

.status-pending {
    background-color: #fff3e0;
    color: #ff9800;
}

.status-paid {
    background-color: #e8f5e9;
    color: #4caf50;
}

/* 账单内容 */
.bill-content {
    padding: 24rpx;
}

.bill-amount-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.amount-label {
    font-size: 28rpx;
    color: #666;
}

.amount-value {
    font-size: 36rpx;
    color: #e64340;
    font-weight: bold;
}

/* 账单底部 */
.bill-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16rpx 24rpx;
    background-color: #fafafa;
}

.bill-time {
    font-size: 22rpx;
    color: #999;
}

.bill-actions {
    display: flex;
    gap: 16rpx;
}

.btn-pay {
    background-color: #07c160;
    color: #fff;
    font-size: 24rpx;
    padding: 12rpx 24rpx;
    border-radius: 30rpx;
    border: none;
    line-height: 1.4;
}

.btn-pay::after {
    border: none;
}

.btn-detail {
    background-color: #f5f5f5;
    color: #666;
    font-size: 24rpx;
    padding: 12rpx 24rpx;
    border-radius: 30rpx;
    border: none;
    line-height: 1.4;
}

.btn-detail::after {
    border: none;
}

/* 空状态 */
.empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100rpx 0;
}

.empty-icon {
    font-size: 100rpx;
    margin-bottom: 20rpx;
}

.empty-text {
    font-size: 32rpx;
    color: #999;
    margin-bottom: 10rpx;
}

.empty-desc {
    font-size: 26rpx;
    color: #ccc;
}

/* 加载状态 */
.loading {
    text-align: center;
    padding: 30rpx;
    color: #999;
    font-size: 26rpx;
}

/* 没有更多 */
.no-more {
    text-align: center;
    padding: 30rpx;
    color: #999;
    font-size: 26rpx;
}

/* 底部占位 */
.bottom-placeholder {
    height: 120rpx;
}
