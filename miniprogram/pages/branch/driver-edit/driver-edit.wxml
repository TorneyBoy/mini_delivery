<!--pages/branch/driver-edit/driver-edit.wxml-->
<view class="driver-edit-container">
  <!-- 表单 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>
    
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    
    <view class="form-item" wx:if="{{mode === 'add'}}">
      <text class="form-label">密码</text>
      <input class="form-input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>
  </view>

  <!-- 状态开关（编辑模式显示） -->
  <view class="settings-section" wx:if="{{mode === 'edit'}}">
    <view class="setting-item">
      <view class="setting-left">
        <text class="setting-title">账号状态</text>
        <text class="setting-desc">禁用后司机无法登录</text>
      </view>
      <switch checked="{{status === 1}}" color="#52c41a" bindchange="onStatusChange" />
    </view>
  </view>

  <!-- 统计信息（查看模式显示） -->
  <view class="stats-section" wx:if="{{mode === 'view'}}">
    <view class="section-title">配送统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{detail.orderCount || 0}}</text>
        <text class="stat-label">配送订单</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{detail.completedCount || 0}}</text>
        <text class="stat-label">已完成</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-section">
    <view class="btn btn-primary" bindtap="handleSubmit" wx:if="{{mode !== 'view'}}">
      <text>{{mode === 'add' ? '创建司机' : '保存修改'}}</text>
    </view>
    <view class="btn btn-danger" wx:if="{{mode === 'edit'}}" bindtap="handleDelete">
      <text>删除司机</text>
    </view>
    <view class="btn btn-default" wx:if="{{mode === 'view'}}" bindtap="switchToEdit">
      <text>编辑司机</text>
    </view>
  </view>
</view>
