/* pages/branch/product-review/product-review.wxss */
.container {
    padding: 20rpx;
    padding-bottom: 40rpx;
}

.list-section {
    background: #fff;
    border-radius: 16rpx;
    padding: 20rpx;
}

.list-item {
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
    border-bottom: none;
}

.item-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16rpx;
}

.header-left {
    display: flex;
    flex-direction: column;
}

.product-name {
    font-size: 32rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
}

.driver-name {
    font-size: 24rpx;
    color: #999;
}

.status {
    font-size: 24rpx;
    padding: 6rpx 16rpx;
    border-radius: 20rpx;
}

.status-pending {
    background: #fff7e6;
    color: #fa8c16;
}

.status-approved {
    background: #f6ffed;
    color: #52c41a;
}

.status-rejected {
    background: #fff2f0;
    color: #ff4d4f;
}

.item-content {
    display: flex;
}

.product-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin-right: 20rpx;
    flex-shrink: 0;
}

.product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.info-row {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 8rpx;
}

.item-footer {
    margin-top: 16rpx;
    padding: 16rpx;
    background: #fff2f0;
    border-radius: 8rpx;
}

.reject-reason {
    font-size: 26rpx;
    color: #ff4d4f;
}

.item-actions {
    margin-top: 16rpx;
    display: flex;
    justify-content: flex-end;
}

.review-btn {
    padding: 12rpx 32rpx;
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
    font-size: 26rpx;
    border-radius: 30rpx;
    border: none;
}

.empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80rpx 0;
}

.empty-icon {
    font-size: 80rpx;
    margin-bottom: 20rpx;
}

.empty-text {
    font-size: 32rpx;
    color: #999;
}

.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40rpx 0;
    color: #999;
    font-size: 28rpx;
}

.loading-spinner {
    width: 40rpx;
    height: 40rpx;
    border: 4rpx solid #f0f0f0;
    border-top-color: #1890ff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 16rpx;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}

/* 弹窗样式 */
.modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    width: 90%;
    max-width: 600rpx;
    background: #fff;
    border-radius: 20rpx;
    overflow: hidden;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
    font-size: 32rpx;
    font-weight: 500;
    color: #333;
}

.modal-close {
    font-size: 40rpx;
    color: #999;
    line-height: 1;
}

.modal-body {
    padding: 30rpx;
}

.review-image {
    width: 100%;
    height: 300rpx;
    margin-bottom: 20rpx;
}

.review-image image {
    width: 100%;
    height: 100%;
    border-radius: 12rpx;
}

.product-detail {
    margin-bottom: 30rpx;
}

.detail-name {
    display: block;
    font-size: 32rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 12rpx;
}

.detail-row {
    display: block;
    font-size: 26rpx;
    color: #666;
    margin-bottom: 8rpx;
}

.review-options {
    display: flex;
    justify-content: center;
    gap: 40rpx;
    margin-bottom: 20rpx;
}

.option-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20rpx 40rpx;
    border: 2rpx solid #e8e8e8;
    border-radius: 12rpx;
}

.option-item.active {
    border-color: #52c41a;
    background: #f6ffed;
}

.option-item.reject-active {
    border-color: #ff4d4f;
    background: #fff2f0;
}

.option-icon {
    font-size: 40rpx;
    color: #999;
    margin-bottom: 8rpx;
}

.option-item.active .option-icon {
    color: #52c41a;
}

.option-item.reject-active .option-icon {
    color: #ff4d4f;
}

.option-text {
    font-size: 26rpx;
    color: #666;
}

.reject-input {
    margin-top: 20rpx;
}

.reject-textarea {
    width: 100%;
    height: 150rpx;
    background: #f5f5f5;
    border-radius: 12rpx;
    padding: 20rpx;
    font-size: 28rpx;
    box-sizing: border-box;
}

.modal-footer {
    display: flex;
    border-top: 1rpx solid #f0f0f0;
}

.cancel-btn,
.confirm-btn {
    flex: 1;
    height: 100rpx;
    font-size: 32rpx;
    border: none;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
}

.cancel-btn {
    background: #fff;
    color: #666;
    border-right: 1rpx solid #f0f0f0;
}

.confirm-btn {
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
}
