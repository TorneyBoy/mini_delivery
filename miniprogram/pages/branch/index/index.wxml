<!--pages/branch/index/index.wxml-->
<view class="branch-container">
  <!-- 顶部欢迎信息 -->
  <view class="header">
    <view class="welcome">
      <text class="welcome-text">欢迎你，{{brandName}}</text>
      <text class="welcome-desc">分管理后台</text>
    </view>
    <view class="header-actions">
      <view class="change-password-btn" bindtap="goToChangePassword">
        <text>修改密码</text>
      </view>
      <view class="logout-btn" bindtap="handleLogout">
        <text>退出登录</text>
      </view>
    </view>
  </view>

  <!-- 数据中心 -->
  <view class="data-overview" bindtap="goToDataCenter">
    <view class="section-title">
      <text>数据中心</text>
      <text class="arrow">></text>
    </view>
    <view class="data-cards">
      <view class="data-card">
        <text class="data-value">{{statistics.shopCount || 0}}</text>
        <text class="data-label">店铺数量</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.driverCount || 0}}</text>
        <text class="data-label">司机数量</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.productCount || 0}}</text>
        <text class="data-label">商品数量</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.orderCount || 0}}</text>
        <text class="data-label">订单总数</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-section">
    <view class="section-title">功能管理</view>
    <view class="menu-grid">
      <view class="menu-item" bindtap="goToShopList">
        <view class="menu-icon" style="background-color: #e6f7ff;">
          <text>🏪</text>
        </view>
        <text class="menu-title">店铺管理</text>
        <text class="menu-desc">管理旗下店铺</text>
      </view>
      
      <view class="menu-item" bindtap="goToDriverList">
        <view class="menu-icon" style="background-color: #f6ffed;">
          <text>🚚</text>
        </view>
        <text class="menu-title">司机管理</text>
        <text class="menu-desc">管理旗下司机</text>
      </view>
      
      <view class="menu-item" bindtap="goToProductList">
        <view class="menu-icon" style="background-color: #fff7e6;">
          <text>📦</text>
        </view>
        <text class="menu-title">商品管理</text>
        <text class="menu-desc">管理商品信息</text>
      </view>
      
      <view class="menu-item" bindtap="goToOrderMonitor">
        <view class="menu-icon" style="background-color: #fff0f6;">
          <text>📋</text>
        </view>
        <text class="menu-title">订单监控</text>
        <text class="menu-desc">查看订单状态</text>
      </view>
      
      <view class="menu-item" bindtap="goToProductReview">
        <view class="menu-icon" style="background-color: #f0f5ff;">
          <text>📷</text>
        </view>
        <text class="menu-title">图片审核</text>
        <text class="menu-desc">审核商品图片</text>
      </view>
      
      <view class="menu-item" bindtap="goToRegistrationRequests">
        <view class="menu-icon" style="background-color: #fff1f0;">
          <text>📝</text>
        </view>
        <text class="menu-title">注册审核</text>
        <text class="menu-desc">审核注册申请</text>
      </view>
      
      <view class="menu-item" bindtap="goToBillStatistics">
        <view class="menu-icon" style="background-color: #e6fffb;">
          <text>💰</text>
        </view>
        <text class="menu-title">账单统计</text>
        <text class="menu-desc">管理店铺账单</text>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-section">
    <view class="section-title">快捷操作</view>
    <view class="quick-btns">
      <view class="quick-btn" bindtap="goToAddShop">
        <text>+ 添加店铺</text>
      </view>
      <view class="quick-btn" bindtap="goToAddDriver">
        <text>+ 添加司机</text>
      </view>
      <view class="quick-btn" bindtap="goToAddProduct">
        <text>+ 添加商品</text>
      </view>
    </view>
  </view>

  <!-- 分享链接 -->
  <view class="share-section">
    <view class="section-title">分享注册链接</view>
    <view class="share-btns">
      <view class="share-btn shop-share" bindtap="shareShopRegister">
        <text class="share-icon">🏪</text>
        <text class="share-text">分享店铺注册链接</text>
      </view>
      <view class="share-btn driver-share" bindtap="shareDriverRegister">
        <text class="share-icon">🚚</text>
        <text class="share-text">分享司机注册链接</text>
      </view>
    </view>
  </view>
</view>
