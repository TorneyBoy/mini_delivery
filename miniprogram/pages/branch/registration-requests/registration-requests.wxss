/* pages/branch/registration-requests/registration-requests.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff, #36cfc9);
  padding: 40rpx 30rpx;
  text-align: center;
}

.pending-count {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.count-number {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
}

.count-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 10rpx;
}

.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.section {
  margin-top: 20rpx;
}

.section-title {
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #fff;
}

.request-list {
  background-color: #fff;
}

.request-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.request-info {
  display: flex;
  align-items: flex-start;
  flex: 1;
}

.request-type {
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.request-type.shop {
  background-color: #e6f7ff;
  color: #1890ff;
}

.request-type.driver {
  background-color: #f6ffed;
  color: #52c41a;
}

.request-detail {
  flex: 1;
}

.request-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.request-meta {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.request-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.request-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-left: 20rpx;
}

.btn-approve, .btn-reject {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.btn-approve {
  background-color: #52c41a;
  color: #fff;
}

.btn-reject {
  background-color: #ff4d4f;
  color: #fff;
}
