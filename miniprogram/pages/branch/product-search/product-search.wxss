/* pages/branch/product-search/product-search.wxss */
.container {
    padding: 20rpx;
    padding-bottom: 40rpx;
}

/* 搜索类型切换 */
.search-type {
    display: flex;
    background: #fff;
    border-radius: 16rpx;
    padding: 10rpx;
    margin-bottom: 20rpx;
}

.type-item {
    flex: 1;
    text-align: center;
    padding: 20rpx 0;
    font-size: 28rpx;
    color: #666;
    border-radius: 12rpx;
    transition: all 0.3s;
}

.type-item.active {
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
}

/* 搜索框 */
.search-box {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 16rpx;
    padding: 16rpx 20rpx;
    margin-bottom: 20rpx;
}

.search-input {
    flex: 1;
    font-size: 28rpx;
    color: #333;
}

.scan-btn {
    padding: 10rpx 20rpx;
    font-size: 36rpx;
}

.search-btn {
    padding: 10rpx 30rpx;
    background: linear-gradient(135deg, #1890ff, #36cfc9);
    color: #fff;
    font-size: 28rpx;
    border-radius: 30rpx;
    margin-left: 20rpx;
}

/* 搜索结果 */
.result-section {
    min-height: 60vh;
}

.product-item {
    display: flex;
    align-items: center;
    background: #fff;
    border-radius: 16rpx;
    padding: 20rpx;
    margin-bottom: 20rpx;
}

.product-image {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin-right: 20rpx;
    flex-shrink: 0;
    background: #f5f5f5;
}

.product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.product-name {
    font-size: 30rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 10rpx;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.product-brand,
.product-spec,
.product-category,
.product-code {
    font-size: 24rpx;
    color: #999;
    margin-bottom: 6rpx;
}

.select-arrow {
    font-size: 32rpx;
    color: #ccc;
    margin-left: 10rpx;
}

/* 空状态 */
.empty-state,
.initial-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 100rpx 0;
}

.empty-icon,
.initial-icon {
    font-size: 100rpx;
    margin-bottom: 30rpx;
}

.empty-text,
.initial-text {
    font-size: 32rpx;
    color: #999;
    margin-bottom: 16rpx;
}

.empty-tip,
.initial-tip {
    font-size: 26rpx;
    color: #bbb;
}

/* 加载状态 */
.loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 0;
    color: #999;
    font-size: 28rpx;
}

.loading-spinner {
    width: 48rpx;
    height: 48rpx;
    border: 4rpx solid #f0f0f0;
    border-top-color: #1890ff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 20rpx;
}

@keyframes spin {
    to {
        transform: rotate(360deg);
    }
}
