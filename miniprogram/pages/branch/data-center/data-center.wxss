/* pages/branch/data-center/data-center.wxss */
.data-center-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 顶部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.date-selector {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.date-text {
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
}

.refresh-btn {
  padding: 10rpx 30rpx;
  background-color: #1890ff;
  border-radius: 30rpx;
}

.refresh-btn text {
  font-size: 28rpx;
  color: #fff;
}

/* 标签 */
.tabs {
  display: flex;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1890ff;
  border-radius: 2rpx;
}

/* 内容区 */
.content {
  padding: 20rpx;
}

.stats-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #1890ff;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stats-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.stats-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 状态列表 */
.status-list {
  display: flex;
  flex-direction: column;
}

.status-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.status-item:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: #666;
}

.status-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 排行榜 */
.rank-list {
  display: flex;
  flex-direction: column;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-index {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.rank-item:nth-child(1) .rank-index {
  background-color: #ff4d4f;
  color: #fff;
}

.rank-item:nth-child(2) .rank-index {
  background-color: #ff7a45;
  color: #fff;
}

.rank-item:nth-child(3) .rank-index {
  background-color: #ffa940;
  color: #fff;
}

.rank-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rank-name {
  font-size: 28rpx;
  color: #333;
}

.rank-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 趋势图 */
.trend-list {
  display: flex;
  flex-direction: column;
}

.trend-item {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.trend-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
}

.trend-header {
  margin-bottom: 16rpx;
}

.trend-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.trend-chart {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.trend-bar {
  width: calc(25% - 10rpx);
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 10rpx;
  text-align: center;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.bar-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #1890ff;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 日期选择弹窗 */
.date-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.date-picker {
  width: 100%;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx;
}

.picker-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.picker-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.picker-option {
  text-align: center;
  padding: 24rpx 0;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
}

.picker-option:active {
  background-color: #e6f7ff;
  color: #1890ff;
}

.picker-cancel {
  text-align: center;
  padding: 24rpx 0;
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #999;
}
