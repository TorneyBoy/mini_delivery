<!--pages/branch/driver-list/driver-list.wxml-->
<view class="driver-list-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索司机姓名或手机号" value="{{searchKey}}" bindinput="onSearchInput" />
    <view class="search-btn" bindtap="handleSearch">搜索</view>
  </view>

  <!-- 列表 -->
  <view class="driver-list" wx:if="{{list.length > 0}}">
    <view class="driver-card" wx:for="{{list}}" wx:key="id">
      <view class="card-header">
        <text class="driver-name">{{item.name}}</text>
        <view class="status-tag {{item.status === 1 ? 'active' : 'inactive'}}">
          {{item.status === 1 ? '正常' : '禁用'}}
        </view>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">手机号：</text>
          <text class="info-value">{{item.phone}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">创建时间：</text>
          <text class="info-value">{{item.createdAt}}</text>
        </view>
      </view>
      <view class="card-footer">
        <view class="btn-detail" bindtap="goToDetail" data-id="{{item.id}}">
          <text>详情</text>
        </view>
        <view class="btn-edit" bindtap="goToEdit" data-id="{{item.id}}">
          <text>编辑</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-text">暂无司机数据</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && list.length > 0}}">
    <text bindtap="loadMore">加载更多</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">
    <text>+ 添加司机</text>
  </view>
</view>
