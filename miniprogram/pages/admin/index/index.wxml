<!--pages/admin/index/index.wxml-->
<view class="admin-container">
  <!-- 顶部欢迎信息 -->
  <view class="header">
    <view class="welcome">
      <text class="welcome-text">欢迎，总管理</text>
      <text class="welcome-desc">配送管理系统</text>
    </view>
    <view class="logout-btn" bindtap="handleLogout">
      <text>退出登录</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-grid">
    <view class="menu-item" bindtap="goToBranchList">
      <view class="menu-icon">
        <text class="iconfont">👥</text>
      </view>
      <text class="menu-title">分管理列表</text>
      <text class="menu-desc">管理所有分管理账号</text>
    </view>
    
    <view class="menu-item" bindtap="goToAddBranch">
      <view class="menu-icon" style="background-color: #f6ffed;">
        <text class="iconfont">➕</text>
      </view>
      <text class="menu-title">新增分管理</text>
      <text class="menu-desc">创建新的分管理账号</text>
    </view>
    
    <view class="menu-item" bindtap="goToStatistics">
      <view class="menu-icon" style="background-color: #fff7e6;">
        <text class="iconfont">📊</text>
      </view>
      <text class="menu-title">数据中心</text>
      <text class="menu-desc">查看全局数据统计</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="data-overview">
    <view class="section-title">数据概览</view>
    <view class="data-cards">
      <view class="data-card">
        <text class="data-value">{{statistics.branchManagerCount || 0}}</text>
        <text class="data-label">分管理数量</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.shopCount || 0}}</text>
        <text class="data-label">店铺总数</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.driverCount || 0}}</text>
        <text class="data-label">司机总数</text>
      </view>
      <view class="data-card">
        <text class="data-value">{{statistics.productCount || 0}}</text>
        <text class="data-label">商品总数</text>
      </view>
    </view>
  </view>

  <!-- 最近分管理 -->
  <view class="recent-section">
    <view class="section-header">
      <text class="section-title">最近添加的分管理</text>
      <text class="section-more" bindtap="goToBranchList">查看全部 ></text>
    </view>
    <view class="branch-list" wx:if="{{branchManagers.length > 0}}">
      <view class="branch-card" wx:for="{{branchManagers}}" wx:key="id">
        <view class="card-header">
          <text class="brand-name">{{item.brandName || '未设置品牌'}}</text>
          <view class="status-tag {{item.status === 1 ? 'active' : 'inactive'}}">
            {{item.status === 1 ? '启用' : '禁用'}}
          </view>
        </view>
        <view class="card-body">
          <text class="phone-text">手机号：{{item.phone}}</text>
        </view>
        <view class="card-footer">
          <view class="btn-setting" bindtap="goToBranchDetail" data-id="{{item.id}}">
            <text>设置</text>
          </view>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无分管理数据</text>
    </view>
  </view>
</view>
