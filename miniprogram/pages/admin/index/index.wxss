/* pages/admin/index/index.wxss */
.admin-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 顶部欢迎信息 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
}

.welcome {
  display: flex;
  flex-direction: column;
}

.welcome-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.welcome-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.logout-btn {
  padding: 16rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
}

.logout-btn text {
  font-size: 26rpx;
  color: #ffffff;
}

/* 功能入口 */
.menu-grid {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

.menu-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e6f7ff;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.menu-icon .iconfont {
  font-size: 40rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999999;
}

/* 数据概览 */
.data-overview {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
}

.data-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.data-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.data-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.data-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 10rpx;
}

/* 最近分管理 */
.recent-section {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-more {
  font-size: 26rpx;
  color: #1890ff;
}

.branch-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.branch-card {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.brand-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.status-tag {
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-tag.active {
  background-color: #f6ffed;
  color: #52c41a;
}

.status-tag.inactive {
  background-color: #fff2f0;
  color: #ff4d4f;
}

.card-body {
  padding: 16rpx 24rpx;
}

.phone-text {
  font-size: 26rpx;
  color: #666666;
}

.card-footer {
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-setting {
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890ff;
  border-radius: 30rpx;
}

.btn-setting text {
  font-size: 26rpx;
  color: #ffffff;
}

.empty-tip {
  padding: 60rpx 0;
  text-align: center;
}

.empty-tip text {
  font-size: 28rpx;
  color: #999999;
}
