<!--pages/admin/branch-detail/branch-detail.wxml-->
<view class="branch-detail-container">
  <!-- 表单 -->
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">品牌名称</text>
      <input class="form-input" placeholder="请输入品牌名称" value="{{brandName}}" bindinput="onBrandNameInput" />
    </view>
    
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
    </view>
    
    <view class="form-item" wx:if="{{mode === 'add'}}">
      <text class="form-label">密码</text>
      <input class="form-input" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>
  </view>

  <!-- 状态开关（设置模式显示） -->
  <view class="status-section" wx:if="{{mode === 'setting'}}">
    <view class="status-header">
      <text class="status-title">账号状态</text>
      <switch checked="{{status === 1}}" color="#1890ff" bindchange="onStatusChange" />
    </view>
    <text class="status-desc">禁用后，该分管理及其下属店铺和司机均无法登录</text>
  </view>

  <!-- 统计信息（设置模式显示） -->
  <view class="stats-section" wx:if="{{mode === 'setting'}}">
    <view class="section-title">统计信息</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{detail.shopCount || 0}}</text>
        <text class="stat-label">店铺数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{detail.driverCount || 0}}</text>
        <text class="stat-label">司机数量</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{detail.productCount || 0}}</text>
        <text class="stat-label">商品数量</text>
      </view>
    </view>
  </view>

  <!-- 创建时间（设置模式显示） -->
  <view class="info-section" wx:if="{{mode === 'setting'}}">
    <view class="info-item">
      <text class="info-label">创建时间</text>
      <text class="info-value">{{detail.createdAt}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-section">
    <view class="btn btn-primary" bindtap="handleSubmit">
      <text>{{mode === 'add' ? '创建' : '保存修改'}}</text>
    </view>
    <view class="btn btn-danger" wx:if="{{mode === 'setting'}}" bindtap="handleDelete">
      <text>删除分管理</text>
    </view>
  </view>
</view>
