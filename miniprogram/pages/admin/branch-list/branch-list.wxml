<!--pages/admin/branch-list/branch-list.wxml-->
<view class="branch-list-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索品牌名称或手机号" value="{{searchKey}}" bindinput="onSearchInput" />
    <view class="search-btn" bindtap="handleSearch">搜索</view>
  </view>

  <!-- 列表 -->
  <view class="branch-list" wx:if="{{list.length > 0}}">
    <view class="branch-card" wx:for="{{list}}" wx:key="id">
      <view class="card-header">
        <view class="brand-name">{{item.brandName || '未设置品牌'}}</view>
        <view class="status-tag {{item.status === 1 ? 'active' : 'inactive'}}">
          {{item.status === 1 ? '启用' : '禁用'}}
        </view>
      </view>
      <view class="card-body">
        <view class="info-row">
          <text class="info-label">手机号：</text>
          <text class="info-value">{{item.phone}}</text>
        </view>
        <view class="info-row">
          <text class="info-label">店铺：</text>
          <text class="info-value">{{item.shopCount || 0}}家</text>
          <text class="info-label" style="margin-left: 40rpx;">司机：</text>
          <text class="info-value">{{item.driverCount || 0}}人</text>
        </view>
      </view>
      <view class="card-footer">
        <view class="btn-setting" bindtap="goToSetting" data-id="{{item.id}}">
          <text>设置</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && list.length === 0}}">
    <text class="empty-text">暂无分管理数据</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore && list.length > 0}}">
    <text bindtap="loadMore">加载更多</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="add-btn" bindtap="goToAddBranch">
    <text>+ 新增分管理</text>
  </view>
</view>
