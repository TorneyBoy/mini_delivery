/* pages/admin/statistics/statistics.wxss */
.statistics-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx 30rpx 40rpx;
}

/* 概览区域 */
.overview-section {
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 30rpx;
}

.overview-section .section-title {
  color: #ffffff;
}

.overview-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.overview-item {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.overview-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.overview-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 统计区域 */
.stats-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.stats-section .section-title {
  color: #333333;
}

.stats-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 12rpx;
}

.stats-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-right: 20rpx;
}

.stats-icon text {
  font-size: 36rpx;
}

.stats-info {
  display: flex;
  flex-direction: column;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.stats-label {
  font-size: 24rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* 刷新按钮 */
.refresh-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1890ff;
  border-radius: 44rpx;
  margin-top: 40rpx;
}

.refresh-btn text {
  font-size: 32rpx;
  color: #ffffff;
}
