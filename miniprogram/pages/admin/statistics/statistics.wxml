<!--pages/admin/statistics/statistics.wxml-->
<view class="statistics-container">
  <!-- 顶部日期选择 -->
  <view class="header">
    <view class="date-selector" bindtap="showDatePicker">
      <text class="date-text">{{dateRange}}</text>
      <text class="arrow">▼</text>
    </view>
    <view class="refresh-btn" bindtap="loadData">
      <text>刷新</text>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tabs">
    <view class="tab-item {{activeTab === 'overview' ? 'active' : ''}}" data-tab="overview" bindtap="switchTab">
      <text>数据概览</text>
    </view>
    <view class="tab-item {{activeTab === 'product' ? 'active' : ''}}" data-tab="product" bindtap="switchTab">
      <text>商品分析</text>
    </view>
    <view class="tab-item {{activeTab === 'branch' ? 'active' : ''}}" data-tab="branch" bindtap="switchTab">
      <text>分管理分析</text>
    </view>
    <view class="tab-item {{activeTab === 'shop' ? 'active' : ''}}" data-tab="shop" bindtap="switchTab">
      <text>店铺分析</text>
    </view>
    <view class="tab-item {{activeTab === 'deliveryStats' ? 'active' : ''}}" data-tab="deliveryStats" bindtap="switchTab">
      <text>送达统计</text>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="content" wx:if="{{activeTab === 'overview'}}">
    <!-- 基础统计 -->
    <view class="stats-section">
      <view class="section-title">全局数据</view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">{{overview.branchManagerCount || 0}}</text>
          <text class="stats-label">分管理数量</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.shopCount || 0}}</text>
          <text class="stats-label">店铺总数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.driverCount || 0}}</text>
          <text class="stats-label">司机总数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{overview.productCount || 0}}</text>
          <text class="stats-label">商品总数</text>
        </view>
      </view>
    </view>

    <!-- 订单统计 -->
    <view class="stats-section">
      <view class="section-title">订单统计</view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">{{overview.totalOrders || 0}}</text>
          <text class="stats-label">订单总数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">¥{{overview.totalAmount}}</text>
          <text class="stats-label">总交易额</text>
        </view>
      </view>
    </view>

    <!-- 订单状态分布 -->
    <view class="stats-section">
      <view class="section-title">订单状态分布</view>
      <view class="status-list">
        <view class="status-item">
          <text class="status-label">待支付</text>
          <text class="status-value">{{orderStatusDist.pending_payment || 0}}</text>
        </view>
        <view class="status-item">
          <text class="status-label">待分配</text>
          <text class="status-value">{{orderStatusDist.pending_assignment || 0}}</text>
        </view>
        <view class="status-item">
          <text class="status-label">待拣货</text>
          <text class="status-value">{{orderStatusDist.pending_pickup || 0}}</text>
        </view>
        <view class="status-item">
          <text class="status-label">待送货</text>
          <text class="status-value">{{orderStatusDist.pending_delivery || 0}}</text>
        </view>
        <view class="status-item">
          <text class="status-label">已完成</text>
          <text class="status-value">{{orderStatusDist.completed || 0}}</text>
        </view>
      </view>
    </view>

    <!-- 账单统计 -->
    <view class="stats-section">
      <view class="section-title">账单统计</view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">{{billStats.totalBills || 0}}</text>
          <text class="stats-label">账单总数</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{billStats.pendingBills || 0}}</text>
          <text class="stats-label">待支付</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">{{billStats.paidBills || 0}}</text>
          <text class="stats-label">已支付</text>
        </view>
      </view>
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-value">¥{{billStats.totalBillAmount}}</text>
          <text class="stats-label">账单总金额</text>
        </view>
        <view class="stats-item">
          <text class="stats-value">¥{{billStats.paidBillAmount}}</text>
          <text class="stats-label">已支付金额</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 商品分析 -->
  <view class="content" wx:if="{{activeTab === 'product'}}">
    <!-- 商品订单量排行榜 -->
    <view class="stats-section">
      <view class="section-title">商品订单量排行榜 TOP10</view>
      <view class="rank-list" wx:if="{{productOrderRank.length > 0}}">
        <view class="rank-item" wx:for="{{productOrderRank}}" wx:key="productId">
          <view class="rank-index">{{index + 1}}</view>
          <view class="rank-info">
            <text class="rank-name">{{item.productName}}</text>
            <text class="rank-value">{{item.orderCount}} 单</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>

    <!-- 商品销量排行榜 -->
    <view class="stats-section">
      <view class="section-title">商品销量排行榜 TOP10</view>
      <view class="rank-list" wx:if="{{productSalesRank.length > 0}}">
        <view class="rank-item" wx:for="{{productSalesRank}}" wx:key="productId">
          <view class="rank-index">{{index + 1}}</view>
          <view class="rank-info">
            <text class="rank-name">{{item.productName}}</text>
            <text class="rank-value">{{item.salesQuantity}} {{item.unit}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>

    <!-- 销量趋势 -->
    <view class="stats-section">
      <view class="section-title">商品销量趋势</view>
      <view class="trend-list" wx:if="{{salesTrend.length > 0}}">
        <view class="trend-item" wx:for="{{salesTrend}}" wx:key="productId">
          <view class="trend-header">
            <text class="trend-name">{{item.productName}}</text>
          </view>
          <view class="trend-chart">
            <view class="trend-bar" wx:for="{{item.dailyData}}" wx:key="date" wx:for-item="day">
              <view class="bar-label">{{day.date}}</view>
              <view class="bar-value">{{day.quantity}}</view>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>
  </view>

  <!-- 分管理分析 -->
  <view class="content" wx:if="{{activeTab === 'branch'}}">
    <!-- 入账分布 -->
    <view class="stats-section">
      <view class="section-title">分管理入账排行</view>
      <view class="rank-list" wx:if="{{revenueByBranch.length > 0}}">
        <view class="rank-item" wx:for="{{revenueByBranch}}" wx:key="branchManagerId">
          <view class="rank-index">{{index + 1}}</view>
          <view class="rank-info">
            <view class="rank-detail">
              <text class="rank-name">{{item.brandName}}</text>
              <text class="rank-sub">店铺数: {{item.shopCount}}</text>
            </view>
            <text class="rank-value">¥{{item.revenue}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>
  </view>

  <!-- 店铺分析 -->
  <view class="content" wx:if="{{activeTab === 'shop'}}">
    <!-- 入账分布 -->
    <view class="stats-section">
      <view class="section-title">店铺入账排行 TOP10</view>
      <view class="rank-list" wx:if="{{revenueByShop.length > 0}}">
        <view class="rank-item" wx:for="{{revenueByShop}}" wx:key="shopId">
          <view class="rank-index">{{index + 1}}</view>
          <view class="rank-info">
            <text class="rank-name">{{item.shopName}}</text>
            <text class="rank-value">¥{{item.revenue}}</text>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>

    <!-- 店铺数量变化趋势 -->
    <view class="stats-section">
      <view class="section-title">店铺数量变化趋势</view>
      <view class="trend-list" wx:if="{{shopTrend.length > 0}}">
        <view class="trend-chart shop-trend">
          <view class="trend-bar" wx:for="{{shopTrend}}" wx:key="date">
            <view class="bar-label">{{item.date}}</view>
            <view class="bar-value">{{item.count}}</view>
          </view>
        </view>
      </view>
      <view class="empty-tip" wx:else>
        <text>暂无数据</text>
      </view>
    </view>
  </view>

  <!-- 送达数据统计（总管理只看送达数据） -->
  <view class="content" wx:if="{{activeTab === 'deliveryStats'}}">
    <view class="stats-section tips-section">
      <view class="tips-text">送达数据按日期整理，了解商品销量趋势</view>
    </view>
    <view class="stats-section" wx:for="{{deliveryStatsByDate}}" wx:key="date">
      <view class="section-title">
        <text>{{item.date}}</text>
        <text class="sub-title">（{{item.totalDeliveries}}次送达）</text>
      </view>
      <view class="product-table">
        <view class="table-header">
          <view class="table-cell">商品名称</view>
          <view class="table-cell">送达数量</view>
        </view>
        <view class="table-body">
          <view class="table-row" wx:for="{{item.products}}" wx:for-item="product" wx:key="productId">
            <view class="table-cell product-name">{{product.productName}}</view>
            <view class="table-cell">{{product.deliveredQuantity}} {{product.unit}}</view>
          </view>
        </view>
        <view class="empty-tip" wx:if="{{!item.products || item.products.length === 0}}">
          <text>暂无数据</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{deliveryStatsByDate.length === 0}}">
      <text>暂无送达数据</text>
    </view>
  </view>

  <!-- 日期选择弹窗 -->
  <view class="date-picker-mask" wx:if="{{showDatePicker}}" bindtap="hideDatePicker">
    <view class="date-picker" catchtap="">
      <view class="picker-title">选择时间范围</view>
      <view class="picker-options">
        <view class="picker-option" data-range="week" bindtap="selectDateRange">近一周</view>
        <view class="picker-option" data-range="month" bindtap="selectDateRange">近一个月</view>
        <view class="picker-option" data-range="quarter" bindtap="selectDateRange">近三个月</view>
        <view class="picker-option" data-range="year" bindtap="selectDateRange">近一年</view>
      </view>
      <view class="picker-cancel" bindtap="hideDatePicker">取消</view>
    </view>
  </view>
</view>
