/* pages/register/register.wxss */
.register-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 40rpx 30rpx;
}

.register-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999999;
}

.register-form {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-of-type {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.address-input {
  padding-right: 20rpx;
}

.map-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #52c41a;
  border-radius: 12rpx;
  margin-left: 10rpx;
}

.map-icon {
  font-size: 32rpx;
}

.btn-register {
  margin-top: 60rpx;
  width: 100%;
  height: 88rpx;
  background-color: #52c41a;
  color: #ffffff;
  font-size: 32rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-register:active {
  opacity: 0.8;
}
